# =====================================================
# PyNote — environment template
# Copy to .env and fill values. NEVER commit .env.
# =====================================================

# ---- Runtime mode ----
# free  = university-project free-tier providers (GH Models, Gemini, BGE local, Edge TTS)
# prod  = paid providers (Anthropic direct, Voyage, ElevenLabs)
PROVIDER_TIER=free
ENVIRONMENT=development
LOG_LEVEL=info

# ---- Postgres ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pynote
POSTGRES_USER=pynote
POSTGRES_PASSWORD=pynote_dev_password
DATABASE_URL=postgresql+psycopg://pynote:pynote_dev_password@localhost:5432/pynote

# ---- Redis (arq) ----
REDIS_URL=redis://localhost:6379/0

# ---- Object store (MinIO in dev, R2 in deploy) ----
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=pynote
S3_SECRET_ACCESS_KEY=pynote_dev_password
S3_BUCKET=pynote-sources
S3_FORCE_PATH_STYLE=true

# ---- LLM: chat (citation-critical) ----
# Free path: Claude via GitHub Models. Get token: https://github.com/settings/tokens (no scopes needed)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://models.inference.ai.azure.com
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# Optional direct Anthropic for demo-day burst:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---- LLM: cheap ops (Gemini free tier) ----
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL_CHEAP=gemini-2.5-flash-lite
GEMINI_MODEL_HEAVY=gemini-2.5-pro

# ---- Embeddings ----
# free default: BGE-small via fastembed (~130MB ONNX, 384-dim, CPU-fast).
# Other options: bge-m3-local (~2GB, 1024-dim), voyage (paid, 1024-dim).
# Changing dim requires an Alembic migration to drop and recreate the chunk.embedding column.
EMBEDDING_PROVIDER=bge-small-local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
VOYAGE_API_KEY=

# ---- Reranker (Voyage rerank-2.5 — first 200M tokens/month FREE) ----
RERANK_PROVIDER=voyage
RERANK_MODEL=rerank-2.5

# ---- Clerk auth ----
# Get keys: https://dashboard.clerk.com
# Leave CLERK_JWKS_URL EMPTY in dev: the API then trusts X-Dev-User / X-Dev-Org
# headers so you can build M1/M2 without setting up Clerk. Set it to enable real JWT auth,
# e.g. https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# ---- LangSmith observability (free hobby tier) ----
# Get key: https://smith.langchain.com/settings
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pynote-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY_WEB=

# ---- Worker ----
WORKER_CONCURRENCY=4
